# ---------------------------------------------------------------------------
# QuickCap automation - NON-SENSITIVE configuration only.
# NEVER put usernames, passwords, tokens, or API keys in this file.
# You always log in to QuickCap manually in the Chrome window.
# ---------------------------------------------------------------------------

# Main QuickCap URL (home/login page)
QUICKCAP_URL=https://your-quickcap-server.example.com

# Direct URL of the "Request To Login" list page.
# If you don't have a stable direct URL, set it equal to QUICKCAP_URL and
# navigate to the list page manually when the script pauses.
QUICKCAP_REQUEST_LIST_URL=https://your-quickcap-server.example.com/path/to/request-to-login

# Option B (connect mode): Chrome DevTools endpoint
CHROME_DEBUG_URL=http://localhost:9222

# Option A (launch mode): folder for the persistent Chrome profile.
# Default: ./chrome-profile inside the project.
# CHROME_PROFILE_DIR=C:\quickcap-automation-profile

# Element wait timeout in milliseconds
DEFAULT_TIMEOUT_MS=15000

# ---------------------------------------------------------------------------
# Local carbon-copy dashboard (webapp/) — used by `python run_webapp.py` and
# `python main.py --mode local`. No real system involved; safe to leave as-is.
# ---------------------------------------------------------------------------
# LOCAL_WEBAPP_HOST=127.0.0.1
# LOCAL_WEBAPP_PORT=5050
